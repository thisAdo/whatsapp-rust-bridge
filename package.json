{
    "name": "whatsapp-rust-bridge",
    "version": "0.5.3",
    "description": "Utilidades de WhatsApp para Node.js puro, sin WebAssembly ni Bun.",
    "author": "João Lucas <jlucaso@hotmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/jlucaso1/whatsapp-rust-bridge.git"
    },
    "type": "module",
    "files": [
        "dist/**/*"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "bench": "npm run build && echo 'Benchmarks deshabilitados en la variante sin WASM.'",
        "bench:node": "npm run bench",
        "build": "mkdir -p dist && cp ts/index.ts dist/index.js && cp ts/index.d.ts dist/index.d.ts",
        "prepare": "npm run build",
        "test": "echo 'Sin pruebas configuradas.'",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "baileys": "^7.0.0-rc.9",
        "libsignal": "git+https://github.com/whiskeysockets/libsignal-node"
    },
    "devDependencies": {
        "@mitata/counters": "^0.0.8",
        "@types/node": "^24.10.1",
        "audio-decode": "^2.1.3",
        "mitata": "^1.0.34",
        "sharp": "^0.34.5",
        "typescript": "^5.9.3"
    },
    "private": false
}
