{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "outDir": ".node-test",
    "rootDir": ".",
    "noEmitOnError": false
  },
  "include": ["test/**/*.ts", "test/**/*.js"]
}